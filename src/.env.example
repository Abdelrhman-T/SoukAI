APP_NAME= "SoukAI"
APP_VERSION= "V1.0"

PRIMARY_LANG = "ar"
DEFAULT_LANG = "en"

################## LLM Config ########################
BACKEND_LITERAL = ["GROQ", "OPENROUTER"]
GENERATION_BACKEND="OPENROUTER"

OPENROUTER_API_KEY = ""
OPENROUTER_URL = "https://openrouter.ai/api/v1/chat/completions"

OPENROUTER_MODEL_LITERAL = ["liquid/lfm-2.5-1.2b-instruct:free","nex-agi/nex-n2-pro:free", "google/gemma-4-26b-a4b-it:free", "moonshotai/kimi-k2.6:free"]
OPENROUTER_MODEL = "moonshotai/kimi-k2.6:free"


GROQ_API_KEY= ""

GROQ_MODEL="openai/gpt-oss-20b"



DEFAULT_INPUT_MAX_CHARACTERS=1024
DEFAULT_MAX_OUTPUT_TOKENS=200
DEFAULT_TEMPERATURE=0.1



SAFETY_BLOCK_MESSAGE = "The request could not be processed because it triggered the safety checks."
INJECTION_BLOCK_MESSAGE = "The request could not be processed because it appears to contain prompt injection."
EMPTY_INPUT_MESSAGE = "`text` must not be empty."
LONG_INPUT_MESSAGE = "`text` exceeds the configured maximum length."

MISSING_ORDER_ID_MESSAGE = "من فضلك أرسل رقم الطلب أو رقم الحجز حتى أقدر أساعدك."
ORDER_NOT_FOUND_MESSAGE = "لم أتمكن من العثور على الطلب. تأكد من رقم الطلب وأعد إرساله."

################## MODEL_PRICING ########################
GROQ_INPUT_PER_1K= 0.0
GROQ_OUTPUT_PER_1K= 0.0

OPENROUTER_INPUT_PER_1K= 0.0
OPENROUTER_OUTPUT_PER_1K= 0.0